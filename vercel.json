{
  "version": 2,
  "builds": [
    { "src": "api/claude.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/claude", "dest": "/api/claude.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/([^/]+)\\.html", "dest": "/public/$1.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
